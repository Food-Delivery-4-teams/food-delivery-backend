# ============ Database (local: container, cloud: RDS) ============ 
DB_USER=fda
DB_PASSWORD=localdevpass
DB_NAME=fda
DB_HOST=postgres                     #Cloud <rds:entrypoint>
DB_PORT=5432

 
# ============ Cache (local: container, cloud: ElastiCache) ============
REDIS_URL=redis://redis:6379/0           #Cloud <elasticache:endpoint>

 
# ============ Object Storage (local: MinIO, cloud: S3) ============

S3_ENDPOINT=http://minio:9000                                       # cloud: leave EMPTY for real S3 
S3_KEY=minioadmin 
S3_SECRET=minioadmin 
S3_BUCKET=fda-uploads-local       # cloud: fda-uploads-prod 
AWS_REGION=us-east-1              # cloud: actual region 

# ============ Email (local: Mailhog, cloud: SES) ============ 
SMTP_HOST=mailhog 
SMTP_PORT=1025 
SMTP_USER=                        # cloud: SES SMTP user 
SMTP_PASS=                        # cloud: SES SMTP pass 

# ============ App ============ 
NODE_ENV=development              # cloud: production 
LOG_LEVEL=debug                   # cloud: info 

